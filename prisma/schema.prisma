// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

enum UserRole {
  PARENT
  CHILD
  ADMIN
}

enum AchievementCategory {
  SPORTS
  ACADEMICS
  ARTS
  CODING
  MUSIC
  OTHER
}

enum SchoolStatus {
  ACTIVE
  PILOT
  INACTIVE
}

enum ModerationDecision {
  APPROVED
  PENDING
  REJECTED
  FLAGGED
  UNFLAGGED
  EDITED
  COSIGN_REQUESTED
  COSIGN_COMPLETED
}

model User {
  id            String         @id @default(cuid())
  fullName      String
  email         String         @unique
  phone         String?
  passwordHash  String
  role          UserRole
  isSuspended   Boolean        @default(false)
  // Admin-only metadata
  reviewerTitle String?
  twoFactorEnabled Boolean     @default(false)
  lastActiveAt  DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  sessions      Session[]

  childProfile  ChildProfile?
  achievements  Achievement[]

  parentLinks   ParentChild[] @relation("ParentUser")
  childLinks    ParentChild[] @relation("ChildUser")

  reviewerEvents     ModerationEvent[] @relation("ReviewerEvents")
  messagesSent       Message[]         @relation("MessagesSent")
  messagesReceived   Message[]         @relation("MessagesReceived")
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model ParentChild {
  id             String   @id @default(cuid())
  parentId       String
  childId        String
  accessApproved Boolean  @default(true)
  createdAt      DateTime @default(now())

  parent User @relation("ParentUser", fields: [parentId], references: [id], onDelete: Cascade)
  child  User @relation("ChildUser", fields: [childId], references: [id], onDelete: Cascade)

  @@unique([parentId, childId])
  @@index([parentId])
  @@index([childId])
}

model ChildProfile {
  id              String   @id @default(cuid())
  childId         String   @unique
  child           User     @relation(fields: [childId], references: [id], onDelete: Cascade)
  age             Int
  grade           String?
  school          String
  schoolId        String?
  schoolRel       School?  @relation(fields: [schoolId], references: [id], onDelete: SetNull)
  bio             String
  funFact         String?
  skills          String[]
  interests       String[]
  location        String?
  photoUrl        String?
  isPublic        Boolean  @default(false)
  requireApproval Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([schoolId])
}

model Achievement {
  id           String              @id @default(cuid())
  childId      String
  child        User                @relation(fields: [childId], references: [id], onDelete: Cascade)
  title        String
  category     AchievementCategory
  description  String?
  proofUrl     String?
  proofFileUrl String?
  proofHash    String?
  isApproved   Boolean             @default(false)
  isFlagged    Boolean             @default(false)
  createdAt    DateTime            @default(now())

  events       ModerationEvent[]
  coSigns      CoSign[]

  @@index([childId])
  @@index([category])
  @@index([isApproved])
  @@index([isFlagged])
}

/* --------------------- New models (admin / B2B / audit) --------------------- */

model School {
  id        String       @id @default(cuid())
  name      String       @unique
  city      String?
  notes     String?
  status    SchoolStatus @default(PILOT)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  children  ChildProfile[]
}

model ModerationEvent {
  id            String             @id @default(cuid())
  achievementId String?
  achievement   Achievement?       @relation(fields: [achievementId], references: [id], onDelete: SetNull)
  // Snapshot of the achievement so the audit row stays meaningful even if
  // the achievement itself is later rejected (hard-deleted).
  achievementTitle    String?
  achievementCategory AchievementCategory?
  childId             String?
  reviewerId    String
  reviewer      User               @relation("ReviewerEvents", fields: [reviewerId], references: [id], onDelete: Cascade)
  decision      ModerationDecision
  reviewMs      Int?               // wall-clock time between achievement.createdAt and this event
  notes         String?
  createdAt     DateTime           @default(now())

  @@index([achievementId])
  @@index([reviewerId])
  @@index([decision])
  @@index([createdAt])
}

model Message {
  id          String   @id @default(cuid())
  fromUserId  String
  fromUser    User     @relation("MessagesSent", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUserId    String
  toUser      User     @relation("MessagesReceived", fields: [toUserId], references: [id], onDelete: Cascade)
  subject     String
  body        String
  readAt      DateTime?
  createdAt   DateTime @default(now())

  @@index([toUserId])
  @@index([fromUserId])
  @@index([createdAt])
}

model CoSign {
  id            String   @id @default(cuid())
  achievementId String
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  requestedBy   String   // userId of the parent who initiated the request
  signerName    String?
  signerTitle   String?
  signerEmail   String
  note          String?
  token         String   @unique
  signedAt      DateTime?
  expiresAt     DateTime
  createdAt     DateTime @default(now())

  @@index([achievementId])
  @@index([token])
}

model AdminConfig {
  id                String   @id @default("singleton")
  autoApproveParent Boolean  @default(true)
  holdChildUploads  Boolean  @default(true)
  requireProof      Boolean  @default(false)
  csamHashCheck     Boolean  @default(true)
  updatedAt         DateTime @updatedAt
}
